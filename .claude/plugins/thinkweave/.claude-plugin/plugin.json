{
  "name": "thinkweave",
  "version": "0.1.0",
  "description": "Obsidian-native universal memory layer for Claude Code",
  "mcpServers": {
    "thinkweave": {
      "type": "stdio",
      "command": "uv",
      "args": ["run", "--project", "${CLAUDE_PLUGIN_ROOT}", "--extra", "mcp", "weave-mcp"],
      "env": {}
    }
  },
  "post_install": "weave hooks install && weave install --yes"
}
