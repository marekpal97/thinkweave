#!/bin/sh
# Portable MCP-server launcher.
#
# The committed .mcp.json (project scope) and .claude-plugin/plugin.json
# (plugin route) both launch the MCP server through this script instead of a
# bare `uv` command. Rationale (#52): the Claude Code harness environment
# frequently lacks ~/.local/bin on PATH (non-login shells), so a bare `uv`
# made the server SILENTLY fail to launch — no error surfaced, the weave_*
# tools just never appeared. This script resolves uv robustly and, when it
# genuinely isn't installed, fails LOUDLY with an actionable one-liner.
#
# Resolution order: PATH -> ~/.local/bin/uv -> $UV_INSTALL_DIR/uv.
#
# Deliberately shell-builtin-only (no dirname/readlink/basename) so it runs
# on minimal harness shells even with a stripped PATH.
set -eu

# Self-locate the project root (parent of this script's bin/), following
# symlinks (`cd -P`) so the dev-link route resolves to the real checkout —
# same trick as bin/weave. Never relies on the caller's cwd.
case $0 in
    */*) script_dir=${0%/*} ;;
    *)   script_dir=. ;;
esac
root=$(CDPATH='' cd -P -- "$script_dir/.." && pwd)

if command -v uv >/dev/null 2>&1; then
    uv_bin=$(command -v uv)
elif [ -x "${HOME:-}/.local/bin/uv" ]; then
    uv_bin="$HOME/.local/bin/uv"
elif [ -n "${UV_INSTALL_DIR:-}" ] && [ -x "$UV_INSTALL_DIR/uv" ]; then
    uv_bin="$UV_INSTALL_DIR/uv"
else
    echo 'weave-mcp-launch: uv not found (checked PATH, ~/.local/bin/uv, $UV_INSTALL_DIR/uv); install uv from https://docs.astral.sh/uv/getting-started/installation/ or add it to PATH' >&2
    exit 127
fi

exec "$uv_bin" run --project "$root" --extra mcp weave-mcp "$@"
